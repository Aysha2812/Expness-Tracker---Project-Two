<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Expenses</title>
<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<div class="container">

<a href="/">Homepage</a>

<h1>My Expenses</h1>

<a class="button" href="/expenses/new">Add New Expense</a>

<br><br>

<% expenses.forEach(expense=>{ %>

<div class="card">

<p><strong>Title:</strong> <%= expense.title %></p>

<p><strong>Amount:</strong> <%= expense.amount %> BD</p>

<p><strong>Date:</strong> <%= expense.date.getFullYear() %></p>

<p><strong>Category:</strong> <%= expense.category.name %></p>

<p><strong>Payment Method:</strong> <%= expense.paymentMethod %></p>

<a class="button" href="/expenses/<%= expense._id %>">View Expense</a>

</div>

<% }) %>

</div>

</body>
</html>