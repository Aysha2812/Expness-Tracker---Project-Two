<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Edit Expense</title>
</head>
<body>

<h1>Edit Expense</h1>

<form action="/expenses/<%= expense._id %>?_method=PUT" method="POST">

<label>Title:</label>
<input type="text" name="title" value="<%= expense.title %>" required>

<br><br>

<label>Amount:</label>
<input type="number" name="amount" value="<%= expense.amount %>" required>

<br><br>

<label>Date:</label>
<input type="date" name="date" value="<%= expense.date %>" required>

<br><br>

<label>Description:</label>
<input type="text" name="description" value="<%= expense.description %>">

<br><br>

<label>Payment Method:</label>
<input type="text" name="paymentMethod" value="<%= expense.paymentMethod %>">

<br><br>

<button type="submit">Update Expense</button>

</form>

<a href="/expenses">Back</a>

</body>
</html>