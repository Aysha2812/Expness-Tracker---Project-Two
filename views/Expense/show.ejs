<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Expense Details</title>
<link rel="stylesheet" href="/css/style.css">
</head>

<body>

<div class="container">

<a href="/">Homepage</a>

<div class="card">

<h1>Expense Details</h1>

<p><strong>Title:</strong> <%= expense.title %></p>

<p><strong>Amount:</strong> <%= expense.amount %> BD</p>

<p><strong>Date:</strong> <%= expense.date %></p>

<p><strong>Description:</strong> <%= expense.description %></p>

<p><strong>Payment Method:</strong> <%= expense.paymentMethod %></p>

<a class="button" href="/expenses/<%= expense._id %>/edit">
Edit Expense
</a>

<br><br>

<form action="/expenses/<%= expense._id %>?_method=DELETE" method="POST">
<button type="submit">Delete Expense</button>
</form>

<br>

<a href="/expenses">Back to Expenses</a>

</div>

</div>

</body>
</html>