<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Categories</title>
</head>
<body>
<a href="/">Homepage</a>
<a href="/categories/new">Add New Category</a>
<h1>My Categories</h1>

<% categories.forEach(category=>{ %>

<p><strong>Category Name:</strong> <%= category.name %></p>

<a href="/categories/<%= category._id %>">View Category</a>

<hr>

<% }) %>

</body>
</html>