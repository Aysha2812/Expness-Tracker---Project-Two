<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Budget Details</title>
</head>
<body>

<a href="/">Homepage</a>

<h1>Budget Details</h1>

<p><strong>Amount:</strong> <%= budget.amount %> BD</p>
<p><strong>Month:</strong> <%= budget.month %></p>

<a href="/budgets/<%= budget._id %>/edit">Edit Budget</a>

<br><br>

<form action="/budgets/<%= budget._id %>?_method=DELETE" method="POST">
<button type="submit">Delete Budget</button>
</form>

<br>

<a href="/budgets">Back to Budgets</a>

</body>
</html>